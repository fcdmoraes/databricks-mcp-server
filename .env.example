# Server configuration
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.xx.azuredatabricks.net


# ── Authentication ──────────────────────────────────────────────────────────────
#
# The server picks the authentication type automatically, in this priority order:
#   1. OAuth 2.0 Client Credentials (M2M) — if CLIENT_ID and CLIENT_SECRET are set
#   2. Personal Access Token (PAT)        — if DATABRICKS_TOKEN is set
#   3. OAuth U2M (interactive login)       — if none of the above are set
#
# Fill in ONE option below. To use the interactive U2M flow, leave all the
# credential variables empty (keep only DATABRICKS_HOST) and authenticate through
# the start_auth / check_auth tools; the token is cached in ~/.databricks/token-cache.json.

# Option 1: Personal Access Token (PAT)
DATABRICKS_TOKEN=your_personal_access_token_here

# Option 2: OAuth 2.0 Client Credentials (M2M)
DATABRICKS_CLIENT_ID=your_client_id_here
DATABRICKS_CLIENT_SECRET=your_client_secret_here

# Option 3: OAuth U2M (interactive) — leave Options 1 and 2 empty and use start_auth

# ──────────────────────────────────────────────────────────────────────────────

# Logging
LOG_LEVEL=WARNING

# Genie Space registry
# Add one block per space, incrementing the number (1, 2, 3...)
# DESCRIPTION is optional but recommended — Claude uses it to route questions automatically
GENIE_SPACE_1_ID=your_space_id_here
GENIE_SPACE_1_NAME=your_space_name_here
GENIE_SPACE_1_DESCRIPTION=your_space_description_here

# GENIE_SPACE_2_ID=
# GENIE_SPACE_2_NAME=
# GENIE_SPACE_2_DESCRIPTION=