# Databricks API configuration
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.xx.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token_here

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Logging
LOG_LEVEL=INFO 

# Genie Space registry
# Adicione um bloco por space, incrementando o número (1, 2, 3...)
# DESCRIPTION é opcional mas recomendado — o Claude usa para rotear perguntas automaticamente
GENIE_SPACE_1_ID=your_space_id_here
GENIE_SPACE_1_NAME=your_space_name_here
GENIE_SPACE_1_DESCRIPTION=your_space_description_here

# GENIE_SPACE_2_ID=
# GENIE_SPACE_2_NAME=
# GENIE_SPACE_2_DESCRIPTION=